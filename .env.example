# Upstash Redis (optional) — shared rate limiting for login/register/contact (5 req / 60s per route+IP).
# If omitted, falls back to in-memory rate limit (single Node process only).
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# MongoDB, auth, etc. — copy to `.env.local` and fill in real values.
# Prefer Atlas `mongodb+srv://...` URIs in production for reliable DNS/TLS.
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/

# Public site URL (no trailing slash) — used for certificate QR codes and server-rendered verify links.
# Example: https://anjal-achievements.com
# Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# OpenAI (optional) — enables `/api/ai/assist` for form + reviewer drafts
OPENAI_API_KEY=
# Optional; default: gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Set to false to disable AI assist even if OPENAI_API_KEY is set
# AI_ASSIST_ENABLED=true

# Verbose server logs for AI routes
# AI_DEBUG=1
